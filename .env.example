# Feature Flags
USE_GOOGLE_AMAZON_SEARCH=true  # Use Google Custom Search instead of PA-API for discovery
ENABLE_FULL_SEARCH=false  # Search all queries (slower) vs first 2 queries (faster)
ENABLE_AMAZON_ENRICHMENT=false  # Enable PA-API GetItems to enrich products (currently has issues)
